daisy_plot <- st_read(
  here("data/processed/ES_forest_plot_spatial.gpkg"),
  layer = "trees"
) |>
  filter(plot %in% c("DS_01", "DS_04", "DS_05", "DS_07")) |>
  st_transform(6660)

# Quick crown count comparison across all plots
test_plots <- unique(daisy_plot$plot)

plot_counts <- map_dfr(test_plots, \(p) {
  plot_area <- plot_areas[plot_areas$plot == p, ]
  crowns_in <- crowns_best[
    st_within(st_centroid(crowns_best), plot_area, sparse = FALSE),
  ]
  n_field <- sum(
    daisy_plot$plot == p &
      daisy_plot$crown_class %in% c("Dominant", "Co-dominant")
  )
  tibble(
    plot = p,
    n_crowns = nrow(crowns_in),
    n_field = n_field,
    ratio = round(nrow(crowns_in) / n_field, 2)
  )
})

print(plot_counts)
